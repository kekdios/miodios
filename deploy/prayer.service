[Unit]
Description=Prayer (Next.js)
After=network.target

[Service]
Type=simple
User=deploy
WorkingDirectory=/opt/prayer
Environment=NODE_ENV=production
EnvironmentFile=-/opt/prayer/.env
ExecStart=/usr/bin/node /opt/prayer/node_modules/next/dist/bin/next start --hostname 0.0.0.0 --port 8080
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
