# Sprites API — https://docs.sprites.dev/quickstart
# Token: same shape as SPRITE_TOKEN in the docs (Bearer for the API).
# You can use SPRITE_API_KEY here; the app reads that or SPRITE_TOKEN / SPRITES_TOKEN.

SPRITE_API_KEY=

# Optional. Default: https://api.sprites.dev
# Only change this if your provider documents a compatible Sprites HTTP API base URL.
SPRITES_API_BASE_URL=

# Sprite name from `sprite create <name>` / `sprite list`.
SPRITE_NAME=

# Optional: if set, the last path segment is used as the sprite name when SPRITE_NAME is empty
# (e.g. .../apps/sprite-app-3343 → sprite-app-3343).
SPRITE_APP_URL=
